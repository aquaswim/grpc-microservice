{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "buf@latest",
    "protoc-gen-go@latest",
    "protoc-gen-go-grpc@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null",
      "export PATH=$(go env GOPATH)/bin:$PATH",
      "go install tool"
    ],
    "scripts": {
      "gen": "buf generate"
    }
  }
}
